{
  "version": 2,
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "frontend/dist" } },
    { "src": "api/index.ts", "use": "@vercel/node" }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
