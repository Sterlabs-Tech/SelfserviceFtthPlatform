generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id              String   @id @default(uuid())
  name            String
  active          Boolean  @default(true)
  allowedServices String
  allowedUFs      String
  logoUrl         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orders          Order[]
  users           User[]
}

model LogisticsOperator {
  id            String   @id @default(uuid())
  name          String
  active        Boolean  @default(true)
  regions       String
  slaHours      Int      @default(24)
  zipCode       String?
  street        String?
  number        String?
  complement    String?
  neighborhood  String?
  city          String?
  state         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  businessEnd   String   @default("18:00")
  businessStart String   @default("08:00")
  workHolidays  Boolean  @default(false)
  workSaturdays Boolean  @default(false)
  workSundays   Boolean  @default(false)
  orders        Order[]
  stocks        Stock[]
  users         User[]
}

model User {
  id                  String             @id @default(uuid())
  name                String
  email               String             @unique
  password            String             @default("123456")
  photoUrl            String?
  profile             String
  active              Boolean            @default(true)
  tenantId            String?
  logisticsOperatorId String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deliveries          Order[]            @relation("OrderDeliverer")
  logisticsOperator   LogisticsOperator? @relation(fields: [logisticsOperatorId], references: [id])
  tenant              Tenant?            @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([logisticsOperatorId])
}

model Stock {
  id           String            @id @default(uuid())
  operatorId   String
  region       String
  modelCode    String
  tipo         String            @default("ONT")
  manufacturer String
  quantity     Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  operator     LogisticsOperator @relation(fields: [operatorId], references: [id])

  @@index([operatorId])
}

model Order {
  id                   String             @id @default(uuid())
  tenantId             String
  type                 String
  subscriberId         String
  customerName         String
  customerAddress      String
  customerNumber       String?
  customerComplement   String?
  customerNeighborhood String?
  customerCity         String?
  customerState        String?
  customerZip          String?
  customerPhone        String
  externalId           String?
  source               String
  openingOrigin        String?
  status               String             @default("OPEN")
  logisticsOperatorId  String?
  delivererId          String?
  designatedOntModel   String?
  designatedOntSerial  String?
  nfeNumber            String?
  slaTarget            DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  deliverer            User?              @relation("OrderDeliverer", fields: [delivererId], references: [id])
  operator             LogisticsOperator? @relation(fields: [logisticsOperatorId], references: [id])
  tenant               Tenant             @relation(fields: [tenantId], references: [id])
  history              OrderHistory[]

  @@index([status])
  @@index([createdAt])
  @@index([customerState])
}

model OrderHistory {
  id              String   @id @default(uuid())
  orderId         String
  timestamp       DateTime @default(now())
  responsibleName String
  responsibleId   String?
  eventType       String
  oldStatus       String?
  newStatus       String?
  reason          String?
  evidenceUrl     String?
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
